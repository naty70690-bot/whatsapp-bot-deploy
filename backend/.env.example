# Configurações do WhatsApp Bot
# Copie este arquivo para .env e configure os valores

# Porta do servidor
PORT=5000

# Ambiente (development/production)
NODE_ENV=production

# Senha de admin para painel (mude para algo seguro)
ADMIN_PASSWORD=admin123

# URL do banco de dados (para produção, use PostgreSQL)
DATABASE_URL=./whatsapp_bot.db

# URL base da API (para CORS)
API_BASE_URL=https://SEU_BACKEND_URL

# Configurações do WhatsApp
WHATSAPP_SESSION_PATH=./.wwebjs_auth

# Configurações de segurança
JWT_SECRET=seu_jwt_secret_aqui
CORS_ORIGIN=https://SEU_FRONTEND_URL

# Configurações de rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Configurações de email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_app