{
  "name": "whatsapp-bot-backend",
  "version": "1.0.0",
  "description": "WhatsApp Automated Responses Bot Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg server.js --out-path ../dist --targets node18-win-x64,node18-linux-x64,node18-macos-x64",
    "deploy": "npm run build && echo Build completed! Check ../dist folder",
    "railway": "npm start"
  },
  "keywords": ["whatsapp", "bot", "automated-responses"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "whatsapp-web.js": "^1.23.0",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "body-parser": "^1.20.2",
    "qrcode": "^1.5.3",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "server.js",
    "assets": [
      "../whatsapp_bot.db",
      "../.env"
    ],
    "outputPath": "../dist"
  }
}
