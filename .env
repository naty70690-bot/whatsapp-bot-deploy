# WhatsApp Bot Configuration
# Optimized settings for better performance

# Server Configuration
PORT=5000
NODE_ENV=production

# WhatsApp Client Optimization
WHATSAPP_SESSION_TIMEOUT=3600000
WHATSAPP_QR_REFRESH_INTERVAL=30000
WHATSAPP_RECONNECT_DELAY=5000
WHATSAPP_MAX_RECONNECT_ATTEMPTS=10

# Database Optimization
DB_CACHE_SIZE=1000000
DB_BUSY_TIMEOUT=5000

# Web Interface
WEB_MOBILE_OPTIMIZED=true
WEB_CACHE_QR=true
WEB_STATUS_UPDATE_INTERVAL=2000

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Performance
MEMORY_MONITORING=true
CPU_MONITORING=true
AUTO_RESTART_ON_CRASH=true